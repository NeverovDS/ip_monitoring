# Copy this to .env.deploy (git-ignored), fill in real values, and source it
# before deploying:   set -a; source .env.deploy; set +a
#
# Kamal reads these via .kamal/secrets. Never commit .env.deploy.

# Docker Hub access token (Account Settings → Security → New Access Token).
KAMAL_REGISTRY_PASSWORD=your-docker-hub-access-token

# App database password (Postgres accessory + Rails app share this one value).
IP_MONITORING_DATABASE_PASSWORD=generate-a-strong-random-password

# HTTP Basic credentials for the web UI and /sidekiq dashboard.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password
