# Secrets for Kamal. Safe to commit: contains NO raw values, only references to
# ENV vars and local (git-ignored) files. Populate the ENV vars before deploying,
# e.g. by sourcing a git-ignored .env.deploy (see .env.deploy.example).

# ECR auth token (temporary, ~12h). Kamal uses it to `docker login` locally and
# on the server. Requires AWS CLI configured (our default profile / dmitry-admin).
KAMAL_REGISTRY_PASSWORD=$(aws ecr get-login-password --region eu-north-1)

# Rails master key — read from config/master.key. It is git-ignored, so locally
# it is your real key; in CI a workflow step writes it from the secret first.
RAILS_MASTER_KEY=$(cat config/master.key)

# App DB user password (the RDS master password).
IP_MONITORING_DATABASE_PASSWORD=$IP_MONITORING_DATABASE_PASSWORD

# HTTP Basic credentials protecting the web UI and the /sidekiq dashboard.
ADMIN_USERNAME=$ADMIN_USERNAME
ADMIN_PASSWORD=$ADMIN_PASSWORD
